#!/bin/sh
cat <<EOF

SSH key setup — run manually:

  ssh-keygen -t ed25519 -C "{{ .email }}"
  ssh-add --apple-use-keychain ~/.ssh/id_ed25519
  pbcopy < ~/.ssh/id_ed25519.pub
  open https://github.com/settings/ssh/new

Add to ~/.ssh/config:

  Host *
    AddKeysToAgent yes
    UseKeychain yes
    IdentityFile ~/.ssh/id_ed25519

EOF
